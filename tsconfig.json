{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitOverride": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["agent/**/*", "ai/**/*", "capture/**/*", "utils/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "output"]
}
