{
  "flow_name": "Add Entities and Relationship",
  "base_url": "https://app.questdatamodeler.example.com",
  "steps": [
    {
      "action": "wait",
      "selector": "#model-canvas",
      "label": "Wait for canvas"
    },
    {
      "action": "click",
      "selector": "#add-entity",
      "label": "Add entity: Customer"
    },
    {
      "action": "type",
      "selector": "#entity-name",
      "value": "Customer",
      "label": "Name entity as Customer"
    },
    {
      "action": "press",
      "value": "Enter",
      "label": "Confirm Customer entity"
    },
    {
      "action": "click",
      "selector": "#add-entity",
      "label": "Add entity: Orders"
    },
    {
      "action": "type",
      "selector": "#entity-name",
      "value": "Orders",
      "label": "Name entity as Orders"
    },
    {
      "action": "press",
      "value": "Enter",
      "label": "Confirm Orders entity"
    },
    {
      "action": "click",
      "selector": "#add-relationship",
      "label": "Create relationship Customer → Orders"
    },
    {
      "action": "waitForCanvas",
      "selector": "#model-canvas",
      "label": "Render updated diagram"
    }
  ]
}
