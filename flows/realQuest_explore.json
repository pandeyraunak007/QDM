{
  "flow_name": "Real QDM — Explore New Model dialog",
  "base_url": "http://questpmdmc.myerwin.com/overview",
  "steps": [
    {
      "action": "wait",
      "selector": "text=Welcome back",
      "label": "Wait for the Overview page to render",
      "timeoutMs": 60000
    },
    {
      "action": "wait",
      "selector": "text=Quick Actions",
      "label": "Locate the Quick Actions row",
      "timeoutMs": 30000
    },
    {
      "action": "click",
      "selector": "p:text-is(\"New Model\")",
      "label": "Click the New Model Quick Action"
    },
    {
      "action": "wait",
      "delayMs": 3000,
      "label": "Wait for the New Model dialog to render"
    }
  ]
}
