{
  "flow_name": "Real QDM — Create Logical/Physical Model",
  "base_url": "http://questpmdmc.myerwin.com/overview",
  "cover_narration": "In this walkthrough, we'll create a Logical-Physical model in Quest Data Modeler... a model type that represents both the conceptual structure and the actual database implementation in one place. Let's get started.",
  "outro_narration": "And that's a Logical-Physical model... defined once, stored as both a logical and physical representation. Thanks for watching.",
  "steps": [
    {
      "action": "wait",
      "selector": "text=Welcome back",
      "label": "Wait for the Overview page",
      "narration": "We start on the Overview page...",
      "timeoutMs": 60000
    },
    {
      "action": "wait",
      "selector": "text=Quick Actions",
      "label": "Locate the Quick Actions row",
      "narration": "Find the Quick Actions section...",
      "timeoutMs": 30000
    },
    {
      "action": "click",
      "selector": "p:text-is(\"New Model\")",
      "label": "Open the New Model dialog",
      "narration": "Click New Model to begin."
    },
    {
      "action": "wait",
      "selector": "input[placeholder=\"Model Name\"]",
      "label": "Wait for the New Model dialog",
      "narration": "Once the dialog opens...",
      "timeoutMs": 15000
    },
    {
      "action": "type",
      "selector": "input[placeholder=\"Model Name\"]",
      "value": "Demo_LP_{{timestamp}}",
      "label": "Name the Logical-Physical model",
      "narration": "Enter a name for the model. We're using a timestamp to keep each run unique."
    },
    {
      "action": "click",
      "selector": "label:has-text(\"Logical/Physical\")",
      "label": "Select Logical/Physical model type",
      "narration": "This time, select Logical-Physical as the model type. This combined type captures both the logical structure and the database-level details in one model."
    },
    {
      "action": "wait",
      "selector": "input[placeholder=\"Database\"]",
      "label": "Target Server fields appear",
      "narration": "Notice the Target Server fields appearing below. A physical model needs to know which database platform it targets.",
      "timeoutMs": 8000
    },
    {
      "action": "click",
      "selector": "input[placeholder=\"Database\"]",
      "label": "Open the Database dropdown",
      "narration": "Open the Database dropdown..."
    },
    {
      "action": "click",
      "selector": "li[role=\"option\"]:has-text(\"Microsoft Fabric\")",
      "label": "Pick Microsoft Fabric",
      "narration": "and pick Microsoft Fabric."
    },
    {
      "action": "click",
      "selector": "input[placeholder=\"Version\"]",
      "label": "Open the Version dropdown",
      "narration": "Then open the Version dropdown..."
    },
    {
      "action": "click",
      "selector": "li[role=\"option\"]:has-text(\"Data Warehouse\")",
      "label": "Pick Data Warehouse",
      "narration": "and choose Data Warehouse."
    },
    {
      "action": "click",
      "selector": "button:has-text(\"Create\")",
      "label": "Click Create",
      "narration": "Now click Create."
    },
    {
      "action": "wait",
      "delayMs": 12000,
      "label": "Wait for the diagram editor to load",
      "narration": "Give it a moment as the canvas loads..."
    },
    {
      "action": "click",
      "selector": "[aria-label=\"Add Entity\"]",
      "label": "Activate the Add Entity tool",
      "narration": "Now let's add a couple of entities. Click Add Entity..."
    },
    {
      "action": "wait",
      "delayMs": 800,
      "label": "Tool ready",
      "narration": ""
    },
    {
      "action": "clickAt",
      "selector": "body",
      "x": 700,
      "y": 400,
      "label": "Place the first entity on the canvas",
      "narration": "and place the first entity on the canvas."
    },
    {
      "action": "wait",
      "selector": "input#table-name",
      "label": "Wait for the New Entity dialog",
      "narration": "",
      "timeoutMs": 10000
    },
    {
      "action": "type",
      "selector": "input#table-name",
      "value": "Customer",
      "label": "Name the entity Customer",
      "narration": "Name it Customer..."
    },
    {
      "action": "press",
      "selector": "input#table-name",
      "value": "Tab",
      "label": "Commit the entity name",
      "narration": "Press Tab to confirm..."
    },
    {
      "action": "clickAt",
      "selector": "body",
      "x": 200,
      "y": 750,
      "label": "Click outside the dialog to close it",
      "narration": "and click outside to close the dialog."
    },
    {
      "action": "wait",
      "delayMs": 1500,
      "label": "Customer entity placed",
      "narration": "The Customer entity is now on our canvas."
    },
    {
      "action": "click",
      "selector": "[aria-label=\"Add Entity\"]",
      "label": "Activate Add Entity again",
      "narration": "Add another one..."
    },
    {
      "action": "clickAt",
      "selector": "body",
      "x": 1050,
      "y": 400,
      "label": "Place the second entity on the canvas",
      "narration": "and place it next to Customer."
    },
    {
      "action": "wait",
      "selector": "input#table-name",
      "label": "Wait for the second New Entity dialog",
      "narration": "",
      "timeoutMs": 10000
    },
    {
      "action": "type",
      "selector": "input#table-name",
      "value": "Orders",
      "label": "Name the entity Orders",
      "narration": "This time, name it Orders..."
    },
    {
      "action": "press",
      "selector": "input#table-name",
      "value": "Tab",
      "label": "Commit the second entity name",
      "narration": "press Tab..."
    },
    {
      "action": "clickAt",
      "selector": "body",
      "x": 200,
      "y": 750,
      "label": "Click outside to close the second dialog",
      "narration": "and click outside to confirm."
    },
    {
      "action": "wait",
      "delayMs": 1500,
      "label": "Two entities on the canvas",
      "narration": "Now we have Customer and Orders... ready to relate them."
    },
    {
      "action": "click",
      "selector": "[aria-label=\"Add Relationships\"]",
      "label": "Open the Add Relationships menu",
      "narration": "Open the Add Relationships menu..."
    },
    {
      "action": "wait",
      "selector": "text=Non-Identifying",
      "label": "Wait for the relationship subtype menu",
      "narration": "",
      "timeoutMs": 5000
    },
    {
      "action": "click",
      "selector": ":text-is(\"Non-Identifying\")",
      "label": "Pick a Non-Identifying relationship",
      "narration": "and pick a Non-Identifying relationship."
    },
    {
      "action": "drag",
      "selector": "body",
      "x": 700,
      "y": 390,
      "toX": 1050,
      "toY": 390,
      "steps": 50,
      "label": "Drag from Customer to Orders",
      "narration": "Drag from Customer to Orders to draw the relationship line."
    },
    {
      "action": "wait",
      "delayMs": 2000,
      "label": "Wait for the relationship to render",
      "narration": "The relationship line connects them."
    },
    {
      "action": "click",
      "selector": "[aria-label=\"Select\"]",
      "label": "Switch back to the Select tool",
      "narration": "Switch back to Select..."
    },
    {
      "action": "click",
      "selector": ":text-is(\"Logical\")",
      "label": "Open the view-mode dropdown",
      "narration": "Now... here's what makes this a true Logical-Physical model. Click the mode dropdown..."
    },
    {
      "action": "wait",
      "selector": ":text-is(\"Physical\")",
      "label": "Wait for the view-mode menu",
      "narration": "",
      "timeoutMs": 5000
    },
    {
      "action": "click",
      "selector": ":text-is(\"Physical\")",
      "label": "Switch to the Physical view",
      "narration": "and switch to the Physical view."
    },
    {
      "action": "wait",
      "delayMs": 3000,
      "label": "Physical view renders",
      "narration": "The Model Explorer now shows database concepts... Tables, Schemas, Stored Procedures, Views, and Functions. Same model... a different lens."
    },
    {
      "action": "click",
      "selector": ":text-is(\"Physical\")",
      "label": "Open the view-mode dropdown again",
      "narration": "Switch back to Logical..."
    },
    {
      "action": "wait",
      "selector": ":text-is(\"Logical\")",
      "label": "Wait for the view-mode menu",
      "narration": "",
      "timeoutMs": 5000
    },
    {
      "action": "click",
      "selector": ":text-is(\"Logical\")",
      "label": "Return to the Logical view",
      "narration": "back to where we started."
    },
    {
      "action": "wait",
      "delayMs": 2000,
      "label": "Logical view restored",
      "narration": ""
    },
    {
      "action": "click",
      "selector": "[aria-label=\"Mart\"]",
      "label": "Open the Mart save menu",
      "narration": "Now let's save. Open the Mart menu..."
    },
    {
      "action": "wait",
      "selector": "text=Save as",
      "label": "Wait for the Mart menu",
      "narration": "Wait for the menu...",
      "timeoutMs": 8000
    },
    {
      "action": "click",
      "selector": "li:has-text(\"Save as\")",
      "label": "Choose Save as",
      "narration": "and choose Save As."
    },
    {
      "action": "wait",
      "delayMs": 3000,
      "label": "Save dialog open",
      "narration": "Our Logical-Physical model is ready to be stored in the Mart."
    }
  ]
}
